# Maven / Java 构建输出
target/
out/
bin/
*.class
*.jar
*.war
*.ear
!.mvn/wrapper/maven-wrapper.jar
.flattened-pom.xml
dependency-reduced-pom.xml
.mvn/timing.properties

# IDE 配置文件
.idea/
.vscode/
*.iml
.project
.classpath
.settings/

# 操作系统文件
.DS_Store
Thumbs.db

# 本地环境变量和密钥
.env
.env.*
!.env.example
!.env.*.example
src/main/resources/application-local.yml
src/main/resources/application-*.local.yml

# 运行时数据和日志
data/
logs/
*.log

# JVM 运行诊断与测试临时产物，通常包含本机路径、堆信息或一次性排障输出，不应提交到仓库。
hs_err_pid*
replay_pid*
*.hprof
*.dump
*.dumpstream

# 本地临时目录和工具缓存，仅用于开发机运行或排障过程。
tmp/
temp/
.cache/

# 生成的压缩包
*.zip
*.tar
*.tar.gz
*.tgz
